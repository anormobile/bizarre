# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env*.local
!.env.example

# vercel
.vercel

# logs
*.log

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright mcp session dumps
/.playwright-mcp/

# root debug screenshots (keep only public/ images)
/*.png
/*.jpg
/*.jpeg
/*.gif

# local dev artifacts — dev-time notes, not for review
/issues.md
/not-implemented.md
/qa-report.md
/validation-progress.md
/jar.txt

# user-uploaded attachments (persisted at runtime via docker volume)
/files/attachments/*
!/files/attachments/.gitkeep
